#!/usr/bin/env bash
#SBATCH --job-name=BCDB_s2smiles_anchor_5fold
#SBATCH --partition=gpuA800
#SBATCH --mem=60G
#SBATCH --gres=gpu:4
#SBATCH --time=2-00:00:00
#SBATCH --ntasks-per-node=8
#SBATCH --output=sbatch/sbatch_log/BCDB_s2smiles_anchor_5fold_%A_%a.out
#SBATCH --error=sbatch/sbatch_log/BCDB_s2smiles_anchor_5fold_%A_%a.err
#SBATCH --array=0-19

set -eo pipefail

cd "$SLURM_SUBMIT_DIR"
source ~/.bashrc
conda activate unimacro
cd /share/home/202320162823/cmacro_BCDB

export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"

# with-volume setting for the requested 20 runs (4 variants x 5 folds)
PKL_PATH="/share/home/202320162823/cmacro_BCDB/data/processed/BCDB_chain_withvolume.pkl"
SCRATCH_WT="/share/home/202320162823/cmacro_BCDB/non_exist_for_scratch.pt"

FOLDS=5
VARIANTS=4
idx=${SLURM_ARRAY_TASK_ID}
fold=$(( idx % FOLDS ))
variant=$(( idx / FOLDS ))

MAIN_TASK=""
EQUALIZE=0
STAGE2_REPR="full"
DISABLE_ANCHOR=0
VAR_TAG=""

case ${variant} in
  0)
    # new stage2only: smiles-id-only segment initialization
    MAIN_TASK="stage2_only"; EQUALIZE=0; STAGE2_REPR="smiles_only"; DISABLE_ANCHOR=0; VAR_TAG="stage2only_smiles";;
  1)
    # new stage2onlybig: smiles-id-only + active-params equalization
    MAIN_TASK="stage2_only"; EQUALIZE=1; STAGE2_REPR="smiles_only"; DISABLE_ANCHOR=0; VAR_TAG="stage2onlybig_smiles";;
  2)
    # FRPN with anchor-based symmetry-breaking disabled
    MAIN_TASK="chain"; EQUALIZE=0; STAGE2_REPR="full"; DISABLE_ANCHOR=1; VAR_TAG="frpn_noanchor";;
  3)
    # new stage2only-smiles with anchor-based symmetry-breaking disabled
    MAIN_TASK="stage2_only"; EQUALIZE=0; STAGE2_REPR="smiles_only"; DISABLE_ANCHOR=1; VAR_TAG="stage2only_smiles_noanchor";;
  *)
    echo "Invalid variant index: ${variant}"; exit 2;;
esac

PORT=$(( 29900 + SLURM_ARRAY_TASK_ID ))

echo "[S2-SMILES-ANCHOR] idx=${idx} fold=${fold} variant=${VAR_TAG} main_task=${MAIN_TASK} eq=${EQUALIZE} repr=${STAGE2_REPR} no_anchor=${DISABLE_ANCHOR}"
echo "[S2-SMILES-ANCHOR] pkl=${PKL_PATH}"

ARGS=(
  --main_task "${MAIN_TASK}"
  --fold "${fold}"
  --dataset_name BCDB
  --pkl_path "${PKL_PATH}"
  --epochs 100
  --lr 1e-4
  --weight_decay 1e-2
  --task_type cls
  --batch_size 8
  --num_tasks 2
  --wo_triopm
  --amp
  --seed 42
  --max_chain_tokens 1536
  --weight_path "${SCRATCH_WT}"
  --results_root /share/home/202320162823/cmacro_BCDB/results_stage2_smiles_anchor
  --stage2_only_repr "${STAGE2_REPR}"
  --distributed
)

if [[ ${EQUALIZE} -eq 1 ]]; then
  ARGS+=( --equalize_active_params )
fi

if [[ ${DISABLE_ANCHOR} -eq 1 ]]; then
  ARGS+=( --disable_anchor_symmetry_break )
fi

torchrun --standalone --nproc_per_node=4 --master_port="${PORT}" frpn/pipelines/bcdb/main.py "${ARGS[@]}"
